##
# CreateAI Brain — Fastlane Automation
# iOS + Android store submissions fully automated
# Run locally: bundle exec fastlane ios release
#              bundle exec fastlane android release
##

default_platform(:ios)

APP_ID = "com.lakesidetrinity.createaibrain"
APP_NAME = "CreateAI Brain"

# ── iOS Platform ─────────────────────────────────────────────────────────────
platform :ios do

  before_all do
    ensure_xcode_version(version: "15.0")
  end

  desc "Sync code signing certificates"
  lane :certs do
    match(
      type: "appstore",
      app_identifier: APP_ID,
      readonly: is_ci,
    )
  end

  desc "Run tests"
  lane :test do
    run_tests(
      scheme: "App",
      output_directory: "fastlane/test_output"
    )
  end

  desc "Build and submit to TestFlight (beta)"
  lane :beta do
    certs
    increment_build_number(xcodeproj: "ios/App/App.xcodeproj")
    build_ios_app(
      scheme: "App",
      workspace: "ios/App/App.xcworkspace",
      export_method: "app-store",
      output_directory: "fastlane/builds",
      output_name: "#{APP_NAME}-beta.ipa",
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      app_identifier: APP_ID,
    )
    notification(
      title: "#{APP_NAME} Beta",
      message: "✅ New build uploaded to TestFlight",
      sound: "default"
    ) unless is_ci
  end

  desc "Build and submit to App Store"
  lane :release do
    # 1. Sync certificates and provisioning profiles
    certs

    # 2. Bump build number (auto-increments on each release)
    increment_build_number(xcodeproj: "ios/App/App.xcodeproj")

    # 3. Build the IPA
    build_ios_app(
      scheme: "App",
      workspace: "ios/App/App.xcworkspace",
      export_method: "app-store",
      output_directory: "fastlane/builds",
      output_name: "#{APP_NAME}.ipa",
      xcargs: "-allowProvisioningUpdates",
    )

    # 4. Upload to App Store Connect
    upload_to_app_store(
      app_identifier: APP_ID,
      ipa: "fastlane/builds/#{APP_NAME}.ipa",
      skip_screenshots: false,
      skip_metadata: false,
      metadata_path: "../app-store-submission/fastlane-metadata",
      screenshots_path: "../public/screenshots",
      submit_for_review: true,
      automatic_release: false,
      submission_information: {
        add_id_info_serves_ads: false,
        add_id_info_tracks_action: false,
        add_id_info_tracks_install: false,
        add_id_info_uses_idfa: false,
        content_rights_has_rights: true,
        content_rights_contains_third_party_content: false,
        export_compliance_platform: "ios",
        export_compliance_compliance_required: false,
        export_compliance_encryption_updated: false,
        export_compliance_app_type: nil,
        export_compliance_uses_encryption: false,
        export_compliance_is_exempt: false,
        export_compliance_contains_third_party_cryptography: false,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_available_on_french_store: false,
      }
    )

    # 5. Tag the release
    add_git_tag(tag: "ios-v#{get_version_number(xcodeproj: 'ios/App/App.xcodeproj')}")

    UI.success("✅ #{APP_NAME} submitted to App Store Connect!")
  end

  desc "Upload screenshots only"
  lane :screenshots do
    upload_to_app_store(
      app_identifier: APP_ID,
      skip_binary_upload: true,
      skip_metadata: true,
      screenshots_path: "../public/screenshots",
    )
  end

  error do |lane, exception|
    UI.error("❌ Lane #{lane} failed: #{exception.message}")
  end
end

# ── Android Platform ──────────────────────────────────────────────────────────
platform :android do

  desc "Build debug APK"
  lane :debug do
    gradle(
      task: "assembleDebug",
      project_dir: "android",
    )
  end

  desc "Build release AAB and submit to Google Play (internal track)"
  lane :beta do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android",
      properties: {
        "android.injected.signing.store.file" => ENV["ANDROID_KEYSTORE_FILE"],
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASS"],
        "android.injected.signing.key.alias" => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASS"],
      }
    )
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY_DATA"],
      package_name: APP_ID,
      skip_upload_apk: true,
      skip_upload_aab: false,
    )
    UI.success("✅ #{APP_NAME} AAB submitted to Play Store (internal track)")
  end

  desc "Build release AAB and submit to Google Play (production)"
  lane :release do
    # 1. Build signed release bundle
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android",
      properties: {
        "android.injected.signing.store.file" => ENV["ANDROID_KEYSTORE_FILE"],
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASS"],
        "android.injected.signing.key.alias" => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASS"],
      }
    )

    # 2. Upload to Google Play Store (production)
    upload_to_play_store(
      track: "production",
      rollout: "0.1", # 10% rollout — increase gradually
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY_DATA"],
      package_name: APP_ID,
      skip_upload_apk: true,
      skip_upload_aab: false,
      release_status: "completed",
    )

    UI.success("✅ #{APP_NAME} submitted to Google Play production!")
  end

  error do |lane, exception|
    UI.error("❌ Lane #{lane} failed: #{exception.message}")
  end
end
