{
  "manifest_version": 3,
  "name": "CreateAI Brain",
  "short_name": "CreateAI",
  "version": "1.0.0",
  "description": "The complete AI-powered business OS — 45+ intelligent tools including AI Strategy Engine, Revenue Intelligence, CRM, Project Command, Social Command, and more. By Lakeside Trinity LLC.",
  "author": "Lakeside Trinity LLC",

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Open CreateAI Brain",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "https://createaibrain.app/*",
    "https://*.replit.app/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],

  "homepage_url": "https://createaibrain.app",

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Open CreateAI Brain"
    },
    "open_strategy": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open AI Strategy Engine"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
