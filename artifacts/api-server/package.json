{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "start": "node dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit:run": "tsx ./src/runFullAudit.ts",
    "transcend": "tsx ./src/transcendAll.ts",
    "transcend:master": "tsx ./src/transcend_master.ts",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results.xml"
  },
  "dependencies": {
    "@simplewebauthn/server": "13.3.0",
    "@types/compression": "^1.8.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "openid-client": "^6.8.2",
    "postgres": "^3.4.8",
    "resend": "^6.9.4",
    "stripe": "^20.0.0",
    "stripe-replit-sync": "1.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.3",
    "supertest": "^7.2.2",
    "tsx": "catalog:",
    "vitest": "^4.1.0"
  }
}
