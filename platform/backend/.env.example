# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# URL of the frontend, used for CORS.
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/universal_platform

# ─── Session / Auth ───────────────────────────────────────────────────────────
# Used to sign the session cookie with HMAC. Must be a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The server will refuse to start in production if this is not set.
SESSION_SECRET=replace_with_a_long_random_string

# ─── AI Abstraction Layer (plug in your provider later) ───────────────────────
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434   # for fully local/on-premises AI

# ─── Compliance Engine (plug in later) ────────────────────────────────────────
# HIPAA_AUDIT_ENABLED=true
# AUDIT_LOG_RETENTION_DAYS=2555           # 7 years — HIPAA requirement
