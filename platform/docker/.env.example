# ─── Universal Platform — Environment Variables ────────────────────────────────
#
# Copy this file to .env (same directory) and fill in all values.
# The .env file is read by Docker Compose automatically.
# NEVER commit .env to version control.
#
# Generate SESSION_SECRET:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# ─── Required ─────────────────────────────────────────────────────────────────

# The domain name users will access the platform on.
# Use "localhost" for local development (Caddy will use a self-signed cert).
# Use "platform.yournursinghome.org" for a real deployment (Caddy gets Let's Encrypt cert).
DOMAIN=localhost

# A cryptographically random secret used to sign session cookies.
# Minimum 64 hex characters. Changing this invalidates all existing sessions.
SESSION_SECRET=CHANGE_ME_generate_with_node_crypto_randomBytes_64

# The URL the browser uses to reach the frontend.
# Used by the backend for CORS origin validation.
# For local dev: http://localhost:3000
# For production: https://platform.yournursinghome.org
FRONTEND_URL=https://localhost

# ─── Database ─────────────────────────────────────────────────────────────────

POSTGRES_USER=platform
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=universal_platform

# ─── Session behavior ─────────────────────────────────────────────────────────

# Minutes of inactivity before a session is automatically invalidated.
# HIPAA guidance: 15–30 minutes for clinical systems.
# Set to 0 to disable inactivity checks (not recommended for healthcare use).
SESSION_INACTIVITY_MINUTES=30

# ─── Application ──────────────────────────────────────────────────────────────

# Displayed in MFA QR codes and authenticator app entries.
APP_NAME=Universal Platform

# ─── Future: AI integration ──────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...      (requires enterprise account + BAA for PHI use)
# OLLAMA_BASE_URL=http://ollama:11434  (on-premises AI, no external calls)

# ─── Future: FHIR / EHR integration ─────────────────────────────────────────
# POINTCLICKCARE_CLIENT_ID=...
# POINTCLICKCARE_CLIENT_SECRET=...
# POINTCLICKCARE_FHIR_BASE_URL=https://...
